FROM runpod/pytorch:1.0.3-cu1290-torch260-ubuntu2204

WORKDIR /app

# Python deps — RunPod + transformers stack
COPY requirements-runpod.txt .
RUN pip install --no-cache-dir -r requirements-runpod.txt

# Copy application code
COPY runpod_handler.py .
COPY runpod_model_loader.py .
COPY schemas/ ./schemas/

# Pre-download model during build (not at container start)
# Uses snapshot_download to cache weights without loading into memory
ENV HF_HOME=/app/hf_cache
RUN python -c "from huggingface_hub import snapshot_download; \
    print('[Build] Downloading Qwen2.5-VL-7B-Instruct...'); \
    snapshot_download('Qwen/Qwen2.5-VL-7B-Instruct'); \
    print('[Build] Model cached.')"

ENV PYTHONUNBUFFERED=1

CMD ["python", "-u", "runpod_handler.py"]
